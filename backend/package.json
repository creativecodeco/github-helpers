{
  "name": "github-helpers-backend",
  "version": "1.3.0",
  "description": "Backend API server for GitHub Helpers",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.6.0",
    "helmet": "8.3.0",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "typeorm": "1.1.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
