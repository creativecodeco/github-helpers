{
  "name": "github-helpers",
  "version": "1.0.0",
  "description": "API server and interactive web frontend to generate beautiful GitHub readme stats cards and metrics",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"public/**/*.{html,css,js}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"public/**/*.{html,css,js}\"",
    "release": "release-it"
  },
  "author": "CreativeCode.com.co",
  "license": "MIT",
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "8.5.2",
    "helmet": "8.3.0",
    "sqlite3": "5.1.7"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.1",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.12.7",
    "@types/sqlite3": "3.1.11",
    "@typescript-eslint/eslint-plugin": "7.7.0",
    "@typescript-eslint/parser": "7.7.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.2.5",
    "release-it": "20.2.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5",
    "vitest": "1.5.0"
  }
}
