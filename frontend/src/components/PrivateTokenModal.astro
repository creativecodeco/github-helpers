<!-- Private Token Panel -->
<section
  class="token-panel glass-card"
  style="padding: 24px; display: flex; flex-direction: column; gap: 16px; width: 100%"
>
  <h2
    class="section-title"
    style="
      margin-bottom: 8px;
      font-size: 1.25rem;
      display: flex;
      align-items: center;
      gap: 8px;
    "
  >
    <span data-i18n="private_stats_title">Estadísticas Privadas</span>
    <span
      id="private-stats-badge"
      style="
        font-size: 0.7rem;
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
        padding: 2px 8px;
        border-radius: 9999px;
        font-weight: 600;
        border: 1px solid rgba(245, 158, 11, 0.2);
      "
      >Coming Soon</span
    >
  </h2>

  <p style="color: var(--text-secondary); font-size: 0.85rem; line-height: 1.4">
    <span data-i18n="private_stats_desc">Para incluir tus repositorios privados, registra un Token Personal (PAT). Tus datos se cifran en el servidor.</span>
    <a
      href="/help/tokens"
      target="_blank"
      rel="noopener noreferrer"
      style="color: var(--accent-color); text-decoration: none; font-weight: 500"
      data-i18n="private_stats_guide"
      >Leer Guía de Ayuda &rarr;</a
    >
  </p>

  <div
    id="token-form-container"
    style="opacity: 0.55; pointer-events: none"
    title="Esta característica estará disponible próximamente"
  >
    <!-- State: Unregistered -->
    <div id="token-unregistered" class="">
      <div class="input-group" style="margin-bottom: 12px">
        <label for="token-username" class="input-label" style="font-size: 0.8rem" data-i18n="private_stats_username"
          >Usuario de GitHub</label
        >
        <div class="input-wrapper" style="height: 38px">
          <span class="input-prefix" style="font-size: 0.85rem">@</span>
          <input
            type="text"
            id="token-username"
            placeholder="ej. octocat"
            style="font-size: 0.85rem"
            autocomplete="off"
            disabled
          />
        </div>
      </div>

      <div class="input-group" style="margin-bottom: 12px">
        <label for="token-input" class="input-label" style="font-size: 0.8rem" data-i18n="private_stats_pat"
          >Personal Access Token (PAT)</label
        >
        <div class="input-wrapper" style="height: 38px">
          <input
            type="password"
            id="token-input"
            placeholder="github_pat_..."
            style="font-size: 0.85rem; padding-left: 12px"
            autocomplete="off"
            disabled
          />
        </div>
      </div>

      <!-- Consent Checkbox -->
      <div
        class="consent-wrapper"
        style="display: flex; gap: 8px; align-items: flex-start; margin-bottom: 16px"
      >
        <input
          type="checkbox"
          id="token-consent"
          style="margin-top: 3px; cursor: pointer"
          disabled
        />
        <label
          for="token-consent"
          style="
            color: var(--text-secondary);
            font-size: 0.75rem;
            line-height: 1.3;
            cursor: pointer;
            user-select: none;
          "
          data-i18n="private_stats_consent"
        >
          Acepto que esta aplicación guarde mi token cifrado en su base de datos para consultar mis estadísticas. Puedo revocarlo cuando quiera.
        </label>
      </div>

      <button
        id="btn-save-token"
        class="primary-btn"
        style="width: 100%; height: 38px; font-size: 0.9rem"
        disabled
        data-i18n="private_stats_register_btn"
      >
        Registrar Token
      </button>
    </div>

    <!-- State: Registered -->
    <div id="token-registered" class="hidden" style="text-align: center; padding: 10px 0">
      <div
        style="
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          color: #4ade80;
          font-size: 0.9rem;
          margin-bottom: 12px;
          font-weight: 500;
        "
      >
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span data-i18n="private_stats_active_label">Token Registrado Activo</span>
      </div>
      <p
        style="
          color: var(--text-secondary);
          font-size: 0.8rem;
          margin-bottom: 16px;
          line-height: 1.3;
        "
        data-i18n="private_stats_active_desc"
      >
        Tus repositorios privados ya se están sumando en las consultas.
      </p>

      <!-- Deletion Verification Field -->
      <div
        class="input-group"
        id="revoke-verification-group"
        style="margin-bottom: 12px; text-align: left"
      >
        <label
          for="token-revoke-input"
          class="input-label"
          style="font-size: 0.8rem; color: var(--error-color)"
          data-i18n="private_stats_revoke_label"
          >Introduce tu token para confirmar revocación</label
        >
        <div class="input-wrapper" style="height: 38px">
          <input
            type="password"
            id="token-revoke-input"
            placeholder="Introduce cualquier token tuyo"
            style="font-size: 0.85rem; padding-left: 12px"
            autocomplete="off"
          />
        </div>
      </div>

      <button id="btn-revoke-token" class="danger-btn" data-i18n="private_stats_revoke_btn">Revocar Token</button>

      <div style="margin: 16px 0; border-top: 1px dashed var(--glass-border);"></div>

      <div style="text-align: left; margin-bottom: 12px;">
        <span
          style="font-size: 0.75rem; color: var(--text-secondary); display: block; margin-bottom: 6px;"
          data-i18n="private_stats_purge_label"
        >
          ¿Deseas eliminar todo tu registro de forma permanente?
        </span>
        <button
          id="btn-open-purge-modal"
          class="danger-btn"
          style="background: transparent; border: 1px solid var(--error-color); color: var(--error-color); font-size: 0.8rem; height: 32px; padding: 0 12px; width: auto; font-weight: 500;"
          data-i18n="private_stats_purge_open_btn"
        >
          Eliminar todos mis datos
        </button>
      </div>
    </div>
  </div>

  <!-- Status message -->
  <div
    id="token-status-msg"
    class="hidden"
    style="font-size: 0.8rem; padding: 10px; border-radius: 6px; text-align: center"
  >
  </div>
</section>

<!-- Purge Data Modal -->
<div
  id="purge-modal"
  class="hidden"
  style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.75); backdrop-filter: blur(8px); display: flex; justify-content: center; align-items: center; z-index: 1000;"
>
  <div
    class="glass-card"
    style="width: 90%; max-width: 480px; padding: 28px; border: 1px solid rgba(248, 81, 73, 0.2); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6); display: flex; flex-direction: column; gap: 20px;"
  >
    <div style="display: flex; gap: 12px; align-items: flex-start; color: var(--error-color);">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        style="flex-shrink: 0; margin-top: 2px;"
      >
        <path
          d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
        ></path>
        <line x1="12" y1="9" x2="12" y2="13"></line>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
      <div>
        <h3 style="font-size: 1.15rem; font-weight: 700; margin: 0; line-height: 1.2;" data-i18n="purge_modal_title">
          Eliminar todos mis datos
        </h3>
        <p
          style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 6px; line-height: 1.4;"
          data-i18n="purge_modal_desc"
        >
          Esta acción es <strong>permanente e irreversible</strong>. Eliminará tu token cifrado, tu historial de estadísticas, tus métricas de consumo de cards y todos tus registros de logs del servidor.
        </p>
      </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      <div class="input-group">
        <label for="purge-username" class="input-label" style="font-size: 0.8rem;" data-i18n="purge_modal_confirm_label"
          >Escribe tu usuario de GitHub para confirmar</label
        >
        <div class="input-wrapper" style="height: 38px;">
          <span class="input-prefix" style="font-size: 0.85rem;">@</span>
          <input
            type="text"
            id="purge-username"
            placeholder="ej. octocat"
            style="font-size: 0.85rem;"
            autocomplete="off"
          />
        </div>
      </div>

      <div class="input-group">
        <label for="purge-token" class="input-label" style="font-size: 0.8rem;" data-i18n="purge_modal_token_label"
          >Introduce tu Token de Acceso para autorizar</label
        >
        <div class="input-wrapper" style="height: 38px;">
          <input
            type="password"
            id="purge-token"
            placeholder="github_pat_..."
            style="font-size: 0.85rem; padding-left: 12px;"
            autocomplete="off"
          />
        </div>
      </div>
    </div>

    <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px;">
      <button
        id="btn-close-purge"
        class="theme-option"
        style="padding: 10px 16px; font-size: 0.85rem; border-radius: 8px; width: auto; flex-direction: row; height: 38px;"
        data-i18n="purge_modal_cancel_btn"
      >
        Cancelar
      </button>
      <button
        id="btn-confirm-purge"
        class="danger-btn"
        style="width: auto; height: 38px; padding: 0 20px; font-size: 0.85rem; opacity: 0.5; pointer-events: none;"
        data-i18n="purge_modal_confirm_btn"
      >
        Eliminar todo definitivamente
      </button>
    </div>
  </div>
</div>
