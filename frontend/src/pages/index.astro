---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import PrivateTokenModal from '@/components/PrivateTokenModal.astro';
import CardPreview from '@/components/CardPreview.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout>
  <header class="app-header">
    <div class="header-top-row">
      <div class="logo">
        <svg
          class="logo-icon"
          viewBox="0 0 24 24"
          width="36"
          height="36"
          fill="none"
          stroke="url(#logo-grad)"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#38bdf8"></stop>
              <stop offset="100%" stop-color="#a855f7"></stop>
            </linearGradient>
          </defs>
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
        <h1>GitHub <span class="accent-text">Helpers</span></h1>
      </div>
      <ThemeToggle />
    </div>
    <p class="subtitle" data-i18n="header_subtitle">
      Potencia la visibilidad de tus proyectos. Genera métricas y tarjetas estéticas en caliente para tu README.md.
    </p>
    <!-- Live Metrics counter -->
    <div class="hidden metrics-badge" id="metrics-badge">
      <span class="pulse-dot"></span>
      <span style="display: inline-flex; align-items: center; gap: 4px;">
        <span data-i18n="header_metrics_label">Usuarios usando las cards: </span>
        <strong id="metrics-count">Cargando...</strong>
      </span>
    </div>
  </header>

  <main class="main-content">
    <!-- Left Column Wrapper -->
    <div class="left-column" style="display: flex; flex-direction: column; gap: 24px; width: 100%">
      <!-- Left Panel: Input & Settings -->
      <section class="settings-panel glass-card" style="width: 100%">
        <h2 class="section-title" data-i18n="settings_title">Configuración</h2>

        <!-- Step 1: Username & Optional Repo -->
        <div class="input-group">
          <label for="username-input" class="input-label" data-i18n="username_label">Usuario de GitHub</label>
          <div class="input-wrapper">
            <span class="input-prefix">@</span>
            <input
              type="text"
              id="username-input"
              placeholder="ej. github"
              data-i18n-placeholder="username_placeholder"
              autocomplete="off"
              required
            />
          </div>
        </div>

        <div class="input-group">
          <label for="repo-input" class="input-label" data-i18n="repo_label">Repositorio Específico (Opcional)</label>
          <div class="input-wrapper">
            <span class="input-prefix">
              <svg
                viewBox="0 0 24 24"
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right: 4px"
                aria-hidden="true"
              >
                <path
                  d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <input
              type="text"
              id="repo-input"
              placeholder="ej. github-helpers (o el más popular)"
              data-i18n-placeholder="repo_placeholder"
              autocomplete="off"
            />
          </div>
        </div>

        <button
          id="btn-generate"
          class="primary-btn full-width-btn"
          style="margin-bottom: 24px; width: 100%"
          data-i18n="btn_generate"
        >
          Generar Tarjetas
        </button>

        <!-- Step 3: Themes -->
        <div class="themes-group">          <span class="input-label" data-i18n="theme_label">Selecciona un Estilo</span>
          <div class="themes-grid" id="themes-container">
            <button class="theme-option active" data-theme="dark" id="theme-dark">
              <span class="theme-name">Dark</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #0d1117"></span>
                <span class="color-dot" style="background: #58a6ff"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="light" id="theme-light">
              <span class="theme-name">Light</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #ffffff"></span>
                <span class="color-dot" style="background: #0969da"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="neon" id="theme-neon">
              <span class="theme-name">Neon</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #050505"></span>
                <span class="color-dot" style="background: #00ff66"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="glassmorphism" id="theme-glassmorphism">
              <span class="theme-name">Glass</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: rgba(15, 23, 42, 0.65)"></span>
                <span class="color-dot" style="background: #38bdf8"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="solarized" id="theme-solarized">
              <span class="theme-name">Solarized</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #002b36"></span>
                <span class="color-dot" style="background: #2aa198"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="radical" id="theme-radical">
              <span class="theme-name">Radical</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #141321"></span>
                <span class="color-dot" style="background: #fe428e"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="tokyonight" id="theme-tokyonight">
              <span class="theme-name">Tokyo</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #1a1b26"></span>
                <span class="color-dot" style="background: #79dac8"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="catppuccin_mocha" id="theme-catppuccin_mocha">
              <span class="theme-name">Catppuccin</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #1e1e2e"></span>
                <span class="color-dot" style="background: #cba6f7"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="nord" id="theme-nord">
              <span class="theme-name">Nord</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #2e3440"></span>
                <span class="color-dot" style="background: #88c0d0"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="cyberpunk" id="theme-cyberpunk">
              <span class="theme-name">Cyberpunk</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #0d0221"></span>
                <span class="color-dot" style="background: #f7c59f"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="gruvbox" id="theme-gruvbox">
              <span class="theme-name">Gruvbox</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #282828"></span>
                <span class="color-dot" style="background: #fabd2f"></span>
              </span>
            </button>
            <button class="theme-option" data-theme="synthwave" id="theme-synthwave">
              <span class="theme-name">Synthwave</span>
              <span class="theme-colors">
                <span class="color-dot" style="background: #1a0933"></span>
                <span class="color-dot" style="background: #f97e72"></span>
              </span>
            </button>
          </div>
        </div>

        <!-- Card Width Control -->
        <div class="input-group" style="margin-top: 4px;">
          <label class="input-label" data-i18n="card_width_label">Ancho de Tarjeta</label>
          <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <button
              class="width-option active"
              data-width="default"
              id="width-default"
              style="flex: 1; min-width: 100px; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(88,166,255,0.12); color: var(--text-primary); cursor: pointer; font-size: 0.82rem; font-weight: 600; transition: all 0.2s;"
            >
              <span data-i18n="width_standard">Estándar (495px)</span>
            </button>
            <button
              class="width-option"
              data-width="100%"
              id="width-full"
              style="flex: 1; min-width: 100px; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--glass-border); background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 0.82rem; font-weight: 600; transition: all 0.2s;"
            >
              <span data-i18n="width_full">Ancho Completo (100%)</span>
            </button>
          </div>
          <div style="display: flex; gap: 8px; align-items: center; margin-top: 8px;">
            <div class="input-wrapper" style="flex: 1; height: 36px;">
              <input
                type="text"
                id="custom-width-input"
                placeholder="Personalizado, ej: 600"
                data-i18n-placeholder="custom_width_placeholder"
                autocomplete="off"
                style="font-size: 0.85rem;"
              />
            </div>
            <button
              id="btn-apply-width"
              style="padding: 0 14px; height: 36px; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(56,189,248,0.08); color: var(--text-primary); cursor: pointer; font-size: 0.82rem; font-weight: 600; white-space: nowrap;"
            >
              <span data-i18n="btn_apply">Aplicar</span>
            </button>
          </div>
        </div>

        <!-- Idioma de Tarjetas (i18n) -->
        <div class="input-group" style="margin-top: 16px;">
          <label for="locale-select" class="input-label" data-i18n="locale_label">Idioma de Tarjetas</label>
          <div class="input-wrapper" style="height: 38px;">
            <select
              id="locale-select"
              style="width: 100%; height: 100%; background: transparent; border: none; color: var(--text-primary); font-family: var(--font-family); font-size: 0.85rem; padding-left: 12px; cursor: pointer; outline: none;"
            >
              <option value="es" style="background: var(--bg-color); color: var(--text-primary);" data-i18n="locale_es">
                Español (es)
              </option>
              <option value="en" style="background: var(--bg-color); color: var(--text-primary);" data-i18n="locale_en">
                English (en)
              </option>
            </select>
          </div>
        </div>
      </section>

      <PrivateTokenModal />
    </div>

    <!-- Right Panel: Live Preview & Code -->
    <section class="preview-panel">
      <!-- Live Preview -->
      <div class="preview-card glass-card">
        <h2 class="section-title" data-i18n="preview_title">Vista Previa</h2>
        <div class="cards-preview-container">
          <!-- Profile Views Badge Preview -->
          <CardPreview
            id="views"
            title="Contador de Visitas del Perfil"
            codeLabel="Contador de Visitas"
            frameStyle="min-height: auto; padding: 20px 0;"
            imgStyle="max-height: 20px; object-fit: contain;"
          >
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="36"
              height="36"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>

            <!-- Visitor Counter Options -->
            <div
              slot="options"
              style="padding: 16px; border: 1px solid var(--glass-border); border-radius: 12px; background: rgba(56,189,248,0.04); display: flex; flex-direction: column; gap: 12px; margin-top: 12px; margin-bottom: 12px;"
            >
              <span
                class="input-label"
                style="font-weight: 600; display: flex; align-items: center; gap: 8px;"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="none"
                  stroke="#38bdf8"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle
                    cx="12"
                    cy="12"
                    r="3"></circle></svg
                >
                Contador de Visitas del Perfil
              </span>

              <div class="input-group" style="margin-bottom: 0;">
                <label for="views-label" class="input-label" style="font-size: 0.8rem;"
                  >Etiqueta (Label)</label
                >
                <div class="input-wrapper" style="height: 36px;">
                  <input
                    type="text"
                    id="views-label"
                    placeholder="Profile views"
                    style="font-size: 0.85rem;"
                    value="Profile views"
                    autocomplete="off"
                  />
                </div>
              </div>

              <div style="display: flex; gap: 12px;">
                <div class="input-group" style="flex: 1; margin-bottom: 0;">
                  <label for="views-color" class="input-label" style="font-size: 0.8rem;"
                    >Color acento (Opcional)</label
                  >
                  <div class="input-wrapper" style="height: 36px;">
                    <input
                      type="text"
                      id="views-color"
                      placeholder="ej. blue o hex"
                      style="font-size: 0.85rem;"
                      autocomplete="off"
                    />
                  </div>
                </div>

                <div class="input-group" style="flex: 1; margin-bottom: 0;">
                  <label for="views-style" class="input-label" style="font-size: 0.8rem;"
                    >Estilo</label
                  >
                  <select
                    id="views-style"
                    style="background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: var(--text-primary); border-radius: 8px; padding: 0 10px; font-size: 0.85rem; height: 36px; cursor: pointer; width: 100%; outline: none;"
                  >
                    <option
                      value="flat"
                      style="background: var(--glass-bg); color: var(--text-primary);">flat</option
                    >
                    <option
                      value="flat-square"
                      style="background: var(--glass-bg); color: var(--text-primary);"
                      >flat-square</option
                    >
                  </select>
                </div>
              </div>
            </div>
          </CardPreview>

          <!-- Stats Card Preview -->
          <CardPreview
            id="stats"
            title="Tarjeta de Estadísticas"
            codeLabel="Estadísticas Generales"
          >
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="20" x2="18" y2="10"></line>
              <line x1="12" y1="20" x2="12" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
          </CardPreview>

          <!-- Languages Card Preview -->
          <CardPreview id="languages" title="Tarjeta de Lenguajes" codeLabel="Lenguajes Más Usados">
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
              <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
            </svg>
          </CardPreview>

          <!-- Featured Repo Card Preview -->
          <CardPreview
            id="repo"
            title="Tarjeta de Repositorio Destacado"
            codeLabel="Repositorio Destacado"
          >
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
              ></path>
            </svg>
          </CardPreview>

          <!-- Rank Card Preview -->
          <CardPreview
            id="rank"
            title="Tarjeta de Rango de Desarrollador"
            codeLabel="Rango de Desarrollador"
          >
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          </CardPreview>

          <!-- Streak Stats Card Preview -->
          <CardPreview
            id="streak"
            title="Tarjeta de Racha de Contribuciones"
            codeLabel="Racha de Contribuciones"
          >
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
            </svg>
          </CardPreview>

          <!-- Trophies Card Preview -->
          <CardPreview id="trophies" title="Tarjeta de Trofeos" codeLabel="Trofeos de GitHub">
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
              <path d="M4 22h16"></path>
              <path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path>
              <path d="M12 2a6 6 0 0 1 6 6v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8a6 6 0 0 1 6-6z"></path>
            </svg>
          </CardPreview>

          <!-- Top Repositories Card Preview -->
          <CardPreview id="top-repos" title="Top Repositorios" codeLabel="Top Repositorios">
            <svg
              slot="placeholder-icon"
              class="placeholder-svg"
              viewBox="0 0 24 24"
              width="48"
              height="48"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M3 2.75A2.75 2.75 0 0 1 5.75 0h14.5a.75.75 0 0 1 .75.75v20.5a.75.75 0 0 1-.75.75h-6a.75.75 0 0 1 0-1.5h5.25v-4H5.75A2.75 2.75 0 0 1 3 14.25v-11.5z"
              ></path>
            </svg>
          </CardPreview>
        </div>
      </div>

      <!-- Sample README.md Card / Generator Block -->
      <div class="sample-readme-card glass-card" style="margin-top: 24px; padding: 24px; border-radius: 16px;">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
          <div>
            <h2 class="section-title" style="margin-bottom: 4px;" data-i18n="sample_readme_title">README.md de Ejemplo</h2>
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;" data-i18n="sample_readme_desc">
              Plantilla completa lista para copiar e insertar en tu repositorio de perfil.
            </p>
          </div>
          <a
            href="/help/github-profile"
            class="help-link-btn"
            style="display: inline-flex; align-items: center; gap: 6px; color: var(--accent-color); font-size: 0.82rem; font-weight: 600; text-decoration: none; padding: 8px 14px; border-radius: 8px; background: rgba(56,189,248,0.08); border: 1px solid var(--glass-border); transition: all 0.2s;"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span data-i18n="profile_help_link">¿Cómo crear tu perfil en GitHub?</span> →
          </a>
        </div>

        <!-- Layout Controls & View Mode Tabs -->
        <div class="readme-controls-bar" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 14px; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 10px; border: 1px solid var(--glass-border);">
          <!-- Layout Selector -->
          <div style="display: flex; align-items: center; gap: 6px;">
            <span style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;" data-i18n="readme_layout_label">Diseño:</span>
            <button
              id="btn-readme-layout-vertical"
              class="readme-layout-btn active"
              data-layout="vertical"
              style="padding: 4px 10px; border-radius: 6px; border: 1px solid var(--glass-border); cursor: pointer; font-size: 0.78rem; font-weight: 600; transition: all 0.2s;"
            >
              📱 <span data-i18n="readme_layout_vertical">Vertical</span>
            </button>
            <button
              id="btn-readme-layout-grid"
              class="readme-layout-btn"
              data-layout="grid"
              style="padding: 4px 10px; border-radius: 6px; border: 1px solid var(--glass-border); cursor: pointer; font-size: 0.78rem; font-weight: 600; transition: all 0.2s;"
            >
              📊 <span data-i18n="readme_layout_grid">Tabla (2 Col)</span>
            </button>
          </div>

          <!-- View Mode Tabs (Code vs Live Preview) -->
          <div class="readme-tabs-wrapper" style="display: flex; align-items: center; gap: 4px; background: rgba(0,0,0,0.3); padding: 3px; border-radius: 8px; border: 1px solid var(--glass-border);">
            <button
              id="tab-readme-code"
              class="readme-tab-btn active"
              style="padding: 4px 12px; border-radius: 6px; border: none; cursor: pointer; font-size: 0.78rem; font-weight: 700; transition: all 0.2s;"
            >
              📝 <span data-i18n="tab_readme_code">Código Markdown</span>
            </button>
            <button
              id="tab-readme-preview"
              class="readme-tab-btn"
              style="padding: 4px 12px; border-radius: 6px; border: none; cursor: pointer; font-size: 0.78rem; font-weight: 600; transition: all 0.2s;"
            >
              👁️ <span data-i18n="tab_readme_preview">Vista Previa Live</span>
            </button>
          </div>
        </div>

        <div class="sample-readme-container" style="position: relative;">
          <!-- Markdown Code Box -->
          <textarea
            id="sample-readme-textarea"
            readonly
            rows="8"
            placeholder="Genera tus tarjetas para ver el README.md de ejemplo..."
            data-i18n-placeholder="sample_readme_placeholder"
            style="width: 100%; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--glass-border); border-radius: 10px; padding: 14px; color: #f1f5f9; font-family: monospace; font-size: 0.82rem; line-height: 1.5; resize: vertical; outline: none;"
          ></textarea>

          <!-- Live Preview Render Box (Hidden by default) -->
          <div
            id="sample-readme-rendered"
            class="hidden"
            style="width: 100%; min-height: 180px; max-height: 400px; overflow-y: auto; background: rgba(13, 17, 23, 0.9); border: 1px solid var(--glass-border); border-radius: 10px; padding: 18px; color: #c9d1d9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 0.9rem; line-height: 1.6;"
          >
            <div id="rendered-readme-content">
              <p style="color: var(--text-secondary); text-align: center; margin-top: 40px;" data-i18n="sample_readme_placeholder">
                Genera tus tarjetas para ver el README.md de ejemplo...
              </p>
            </div>
          </div>

          <button
            id="btn-copy-sample-readme"
            class="primary-btn full-width-btn"
            style="margin-top: 12px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span data-i18n="btn_copy_sample_readme">Copiar README.md Completo</span>
          </button>
        </div>
      </div>
    </section>
  </main>

  <div id="toast-container" class="toast-container" aria-live="polite"></div>

  <Footer />
</BaseLayout>

<script>
  import { generateSampleReadme, type CardItem } from '@/utils/readmeGenerator';
  import { t, updateDomTranslations } from '@/utils/i18n';

  // Elements
  const usernameInput = document.getElementById('username-input') as HTMLInputElement | null;
  const repoInput = document.getElementById('repo-input') as HTMLInputElement | null;
  const btnGenerate = document.getElementById('btn-generate');
  const themesContainer = document.getElementById('themes-container');
  const themeOptions = document.querySelectorAll('.theme-option') as NodeListOf<HTMLButtonElement>;

  const statsImg = document.getElementById('stats-img') as HTMLImageElement | null;
  const statsPlaceholder = document.getElementById('stats-placeholder');

  const languagesImg = document.getElementById('languages-img') as HTMLImageElement | null;
  const languagesPlaceholder = document.getElementById('languages-placeholder');

  const repoImg = document.getElementById('repo-img') as HTMLImageElement | null;
  const repoPlaceholder = document.getElementById('repo-placeholder');

  const rankImg = document.getElementById('rank-img') as HTMLImageElement | null;
  const rankPlaceholder = document.getElementById('rank-placeholder');

  const streakImg = document.getElementById('streak-img') as HTMLImageElement | null;
  const streakPlaceholder = document.getElementById('streak-placeholder');

  const trophiesImg = document.getElementById('trophies-img') as HTMLImageElement | null;
  const trophiesPlaceholder = document.getElementById('trophies-placeholder');

  const topReposImg = document.getElementById('top-repos-img') as HTMLImageElement | null;
  const topReposPlaceholder = document.getElementById('top-repos-placeholder');

  const viewsImg = document.getElementById('views-img') as HTMLImageElement | null;
  const viewsPlaceholder = document.getElementById('views-placeholder');

  const codeBlockWrappers = document.querySelectorAll('.code-block-wrapper');
  const markdownStatsCode = document.getElementById('markdown-stats-code');
  const markdownLanguagesCode = document.getElementById('markdown-languages-code');
  const markdownRepoCode = document.getElementById('markdown-repo-code');
  const markdownRankCode = document.getElementById('markdown-rank-code');
  const markdownStreakCode = document.getElementById('markdown-streak-code');
  const markdownTrophiesCode = document.getElementById('markdown-trophies-code');
  const markdownTopReposCode = document.getElementById('markdown-top-repos-code');
  const markdownViewsCode = document.getElementById('markdown-views-code');

  const btnCopyStats = document.getElementById('btn-copy-stats');
  const btnCopyLanguages = document.getElementById('btn-copy-languages');
  const btnCopyRepo = document.getElementById('btn-copy-repo');
  const btnCopyRank = document.getElementById('btn-copy-rank');
  const btnCopyStreak = document.getElementById('btn-copy-streak');
  const btnCopyTrophies = document.getElementById('btn-copy-trophies');
  const btnCopyTopRepos = document.getElementById('btn-copy-top-repos');
  const btnCopyViews = document.getElementById('btn-copy-views');

  const viewsLabel = document.getElementById('views-label') as HTMLInputElement | null;
  const viewsColor = document.getElementById('views-color') as HTMLInputElement | null;
  const viewsStyle = document.getElementById('views-style') as HTMLSelectElement | null;

  // Metrics Elements
  const metricsBadge = document.getElementById('metrics-badge');
  const metricsCount = document.getElementById('metrics-count');

  // Private Stats Elements
  const privateStatsBadge = document.getElementById('private-stats-badge');
  const tokenFormContainer = document.getElementById('token-form-container');

  // Global Loading Overlay
  const globalLoading = document.getElementById('global-loading');

  // Application State
  let currentTheme = 'dark';
  let currentUsername = '';
  let currentRepo = '';
  let currentCardWidth = ''; // empty = default 495px
  let currentLocale = 'es';
  let currentReadmeLayout: 'vertical' | 'grid' = 'vertical';

  const localeSelect = document.getElementById('locale-select') as HTMLSelectElement | null;

  localeSelect?.addEventListener('change', () => {
    currentLocale = localeSelect.value;
    updateDomTranslations(currentLocale);
    const newUrl = new URL(window.location.href);
    newUrl.searchParams.set('locale', currentLocale);
    window.history.pushState({}, '', newUrl.toString());
    if (currentUsername) {
      updateCards();
    }
  });
  // --- Card Width Control ---
  const widthOptions = document.querySelectorAll('.width-option') as NodeListOf<HTMLButtonElement>;
  const customWidthInput = document.getElementById('custom-width-input') as HTMLInputElement | null;
  const btnApplyWidth = document.getElementById('btn-apply-width');

  widthOptions.forEach((btn) => {
    btn.addEventListener('click', () => {
      widthOptions.forEach((b) => {
        b.style.background = 'transparent';
        b.style.color = 'var(--text-secondary)';
        b.classList.remove('active');
      });
      btn.style.background = 'rgba(88,166,255,0.12)';
      btn.style.color = 'var(--text-primary)';
      btn.classList.add('active');
      const w = btn.dataset.width || '';
      currentCardWidth = w === 'default' ? '' : w;
      if (customWidthInput) customWidthInput.value = '';
      if (currentUsername) updateCards();
    });
  });

  btnApplyWidth?.addEventListener('click', () => {
    const val = customWidthInput ? customWidthInput.value.trim() : '';
    if (val) {
      currentCardWidth = val;
      widthOptions.forEach((b) => {
        b.style.background = 'transparent';
        b.style.color = 'var(--text-secondary)';
        b.classList.remove('active');
      });
      if (currentUsername) updateCards();
    }
  });

  // --- SVG Themes Selector disabled state ---
  function updateThemeSelectorsState() {
    const hasUser = !!currentUsername;
    themeOptions.forEach((opt) => {
      opt.disabled = !hasUser;
    });
  }
  updateThemeSelectorsState();

  // --- Metrics Load Logic ---
  async function loadMetrics() {
    if (!metricsBadge || !metricsCount) return;

    metricsCount.textContent = 'Cargando...';
    metricsBadge.classList.remove('hidden');

    try {
      const response = await fetch('/api/metrics/users/count');
      if (response.ok) {
        const count = await response.json();
        metricsCount.textContent = Number(count).toLocaleString();
      } else {
        metricsBadge.classList.add('hidden');
      }
    } catch (err) {
      console.warn('Could not fetch usage metrics:', err);
      metricsBadge.classList.add('hidden');
    }
  }

  loadMetrics();

  // --- SVG Themes Selection logic ---
  themesContainer?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const option = target.closest('.theme-option') as HTMLButtonElement | null;
    if (!option) return;

    themeOptions.forEach((opt) => opt.classList.remove('active'));
    option.classList.add('active');

    currentTheme = option.dataset.theme || 'dark';

    if (currentUsername) {
      const newUrl = new URL(window.location.href);
      newUrl.searchParams.set('theme', currentTheme);
      window.history.pushState({}, '', newUrl.toString());

      updateCards();
    }
  });

  // Generate button handler
  btnGenerate?.addEventListener('click', () => {
    submitUsername();
  });

  // Enter key support in inputs
  usernameInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      submitUsername();
    }
  });

  repoInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      submitUsername();
    }
  });

  function submitUsername() {
    if (!usernameInput) return;
    const usernameVal = usernameInput.value.trim();
    if (!usernameVal) {
      usernameInput.focus();
      return;
    }

    currentUsername = usernameVal;
    currentRepo = repoInput ? repoInput.value.trim() : '';

    const newUrl = new URL(window.location.href);
    newUrl.searchParams.set('user', currentUsername);
    if (currentTheme) {
      newUrl.searchParams.set('theme', currentTheme);
    } else {
      newUrl.searchParams.delete('theme');
    }
    if (currentLocale && currentLocale !== 'es') {
      newUrl.searchParams.set('locale', currentLocale);
    } else {
      newUrl.searchParams.delete('locale');
    }
    window.history.pushState({}, '', newUrl.toString());

    updateThemeSelectorsState();
    updateCards();
  }

  let completedImagesCount = 0;
  const totalImagesToLoad = 8; // stats, languages, repo, rank, streak, trophies, top-repos, views
  let isGeneratingAllCards = false;

  function sortCardsByStatus() {
    const container = document.querySelector('.cards-preview-container');
    if (!container) return;

    const wrappers = Array.from(
      container.querySelectorAll('.card-preview-wrapper')
    ) as HTMLElement[];

    // Separate into success and error groups
    const successCards: HTMLElement[] = [];
    const errorCards: HTMLElement[] = [];

    wrappers.forEach((wrapper) => {
      const placeholder = wrapper.querySelector('.placeholder-card');
      // A card is in error state if the placeholder is visible (not hidden) and has the red error SVG
      const hasErrorSvg = placeholder?.querySelector('svg.error') !== null;
      if (hasErrorSvg) {
        errorCards.push(wrapper);
      } else {
        successCards.push(wrapper);
      }
    });

    // Re-append in order: success first, then errors
    [...successCards, ...errorCards].forEach((wrapper) => container.appendChild(wrapper));
  }

  function renderLiveReadmeHtml(username: string, activeCards: CardItem[], locale: string, layout: 'vertical' | 'grid'): string {
    const cleanUser = username.trim() || 'username';

    if (activeCards.length === 0) {
      return `<h1 style="font-size: 1.4rem; color: #fff; border-bottom: 1px solid #30363d; padding-bottom: 8px; margin-top: 0;">${t('readme_preview_greeting', locale, { username: cleanUser })}</h1>
      <p style="color: #8b949e; margin-bottom: 0;">${t('readme_preview_welcome', locale)}</p>`;
    }

    const titleText = t('readme_preview_greeting', locale, { username: cleanUser });
    const descText = t('readme_preview_desc', locale);
    const sectionTitle = t('readme_preview_section_title', locale);

    let cardsHtml: string;

    if (layout === 'grid') {
      const rows: string[] = [];
      for (let i = 0; i < activeCards.length; i += 2) {
        const c1 = activeCards[i];
        const c2 = activeCards[i + 1];
        if (c2) {
          rows.push(`<tr>
            <td valign="top" style="padding: 6px; width: 50%;">
              <img src="${c1.url}" alt="${c1.title}" style="width: 100%; border-radius: 6px; display: block;" />
            </td>
            <td valign="top" style="padding: 6px; width: 50%;">
              <img src="${c2.url}" alt="${c2.title}" style="width: 100%; border-radius: 6px; display: block;" />
            </td>
          </tr>`);
        } else {
          rows.push(`<tr>
            <td valign="top" style="padding: 6px; width: 50%;">
              <img src="${c1.url}" alt="${c1.title}" style="width: 100%; border-radius: 6px; display: block;" />
            </td>
            <td style="width: 50%;"></td>
          </tr>`);
        }
      }
      cardsHtml = `<table style="width: 100%; border-collapse: collapse;">${rows.join('')}</table>`;
    } else {
      cardsHtml = activeCards
        .map(
          (c) => `<div style="margin-bottom: 12px;">
          <img src="${c.url}" alt="${c.title}" style="max-width: 100%; border-radius: 6px; display: block;" />
        </div>`
        )
        .join('');
    }

    const footerText = t('readme_preview_footer', locale);

    return `
      <h1 style="font-size: 1.4rem; color: #fff; border-bottom: 1px solid #30363d; padding-bottom: 8px; margin-top: 0; margin-bottom: 12px;">${titleText}</h1>
      <p style="color: #8b949e; font-size: 0.9rem; margin-bottom: 16px;">${descText}</p>
      <h3 style="font-size: 1.1rem; color: #e6edf3; margin-bottom: 10px;">${sectionTitle}</h3>
      ${cardsHtml}
      <hr style="border: 0; border-top: 1px solid #30363d; margin: 20px 0 10px 0;" />
      <p style="font-size: 0.8rem; color: #8b949e; font-style: italic; margin: 0;">${footerText}</p>
    `;
  }

  function updateSampleReadmeText() {
    const textarea = document.getElementById('sample-readme-textarea') as HTMLTextAreaElement | null;
    const renderedContainer = document.getElementById('rendered-readme-content');
    if (!textarea || !currentUsername) {
      if (textarea) textarea.value = '';
      if (renderedContainer) {
        renderedContainer.innerHTML = `<p style="color: var(--text-secondary); text-align: center; margin-top: 40px;">${t('sample_readme_placeholder', currentLocale)}</p>`;
      }
      return;
    }

    const cardsConfig = [
      { id: 'views', titleKey: 'title_views' as TranslationKey, getUrl: () => viewsImg?.src },
      { id: 'stats', titleKey: 'title_stats' as TranslationKey, getUrl: () => statsImg?.src },
      { id: 'languages', titleKey: 'title_languages' as TranslationKey, getUrl: () => languagesImg?.src },
      { id: 'streak', titleKey: 'title_streak' as TranslationKey, getUrl: () => streakImg?.src },
      { id: 'rank', titleKey: 'title_rank' as TranslationKey, getUrl: () => rankImg?.src },
      { id: 'trophies', titleKey: 'title_trophies' as TranslationKey, getUrl: () => trophiesImg?.src },
      { id: 'top-repos', titleKey: 'title_top_repos' as TranslationKey, getUrl: () => topReposImg?.src },
      { id: 'repo', titleKey: 'title_repo' as TranslationKey, getUrl: () => repoImg?.src },
    ];

    const activeCards: CardItem[] = [];

    cardsConfig.forEach((cfg) => {
      const img = document.getElementById(`${cfg.id}-img`) as HTMLImageElement | null;
      const placeholder = document.getElementById(`${cfg.id}-placeholder`);
      const hasError = placeholder ? placeholder.querySelector('svg.error') !== null : false;
      const rawUrl = cfg.getUrl();

      if (img && !img.classList.contains('hidden') && !hasError && rawUrl) {
        const cleanUrl = rawUrl.replace(/&t=\d+/, '');
        const title = t(cfg.titleKey, currentLocale);
        activeCards.push({ id: cfg.id, title, url: cleanUrl });
      }
    });

    textarea.value = generateSampleReadme(currentUsername, activeCards, currentLocale, currentReadmeLayout);

    if (renderedContainer) {
      renderedContainer.innerHTML = renderLiveReadmeHtml(currentUsername, activeCards, currentLocale, currentReadmeLayout);
    }
  }

  function imageFinishedLoading() {
    if (!isGeneratingAllCards) return;

    completedImagesCount++;
    if (completedImagesCount >= totalImagesToLoad) {
      if (globalLoading) {
        globalLoading.classList.add('hidden');
      }
      // Sort cards: successful ones first, errored ones last
      sortCardsByStatus();
      updateSampleReadmeText();
      isGeneratingAllCards = false;
    }
  }

  // Update image previews and Markdown blocks
  function updateCards() {
    if (!currentUsername) return;

    isGeneratingAllCards = true;
    completedImagesCount = 0;
    if (globalLoading) {
      globalLoading.classList.remove('hidden');
    }

    const origin = window.location.origin;
    const widthParam = currentCardWidth
      ? `&card_width=${encodeURIComponent(currentCardWidth)}`
      : '';
    const localeParam = currentLocale ? `&locale=${encodeURIComponent(currentLocale)}` : '';

    const statsUrl = `${origin}/api/stats?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    const languagesUrl = `${origin}/api/languages?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    const rankUrl = `${origin}/api/rank?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    const streakUrl = `${origin}/api/streak?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    const trophiesUrl = `${origin}/api/trophies?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    const topReposUrl = `${origin}/api/top-repos?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;

    let repoUrl = `${origin}/api/repo?username=${currentUsername}&theme=${currentTheme}${widthParam}${localeParam}`;
    if (currentRepo) {
      repoUrl += `&repo=${encodeURIComponent(currentRepo)}`;
    }

    const labelVal = viewsLabel ? viewsLabel.value.trim() : '';
    const colorVal = viewsColor ? viewsColor.value.trim() : '';
    const styleVal = viewsStyle ? viewsStyle.value : '';

    let viewsUrl = `${origin}/api/views?username=${currentUsername}&theme=${currentTheme}`;
    if (labelVal) viewsUrl += `&label=${encodeURIComponent(labelVal)}`;
    if (colorVal) viewsUrl += `&color=${encodeURIComponent(colorVal)}`;
    if (styleVal) viewsUrl += `&style=${encodeURIComponent(styleVal)}`;

    // 1. Show Loading State
    showImageLoading(statsImg, statsPlaceholder);
    showImageLoading(languagesImg, languagesPlaceholder);
    showImageLoading(repoImg, repoPlaceholder);
    showImageLoading(rankImg, rankPlaceholder);
    showImageLoading(streakImg, streakPlaceholder);
    showImageLoading(trophiesImg, trophiesPlaceholder);
    showImageLoading(topReposImg, topReposPlaceholder);
    showImageLoading(viewsImg, viewsPlaceholder);

    // 2. Set image sources with cache buster to force rendering updates in preview
    const cacheBuster = `&t=${Date.now()}`;
    if (statsImg) {
      statsImg.src = statsUrl + cacheBuster;
      statsImg.alt = `Tarjeta de estadísticas generales de GitHub para el usuario @${currentUsername}`;
    }
    if (languagesImg) {
      languagesImg.src = languagesUrl + cacheBuster;
      languagesImg.alt = `Tarjeta de lenguajes más usados de GitHub para el usuario @${currentUsername}`;
    }
    if (repoImg) {
      repoImg.src = repoUrl + cacheBuster;
      repoImg.alt = `Tarjeta de repositorio destacado de GitHub para el usuario @${currentUsername}${currentRepo ? ` (repo: ${currentRepo})` : ''}`;
    }
    if (rankImg) {
      rankImg.src = rankUrl + cacheBuster;
      rankImg.alt = `Tarjeta de rango de GitHub para el usuario @${currentUsername}`;
    }
    if (streakImg) {
      streakImg.src = streakUrl + cacheBuster;
      streakImg.alt = `Tarjeta de racha de commits de GitHub para el usuario @${currentUsername}`;
    }
    if (trophiesImg) {
      trophiesImg.src = trophiesUrl + cacheBuster;
      trophiesImg.alt = `Tarjeta de trofeos de GitHub para el usuario @${currentUsername}`;
    }
    if (topReposImg) {
      topReposImg.src = topReposUrl + cacheBuster;
      topReposImg.alt = `Top repositorios de GitHub para el usuario @${currentUsername}`;
    }
    if (viewsImg) {
      viewsImg.src = viewsUrl + cacheBuster;
      viewsImg.alt = `Contador de visitas de GitHub para el usuario @${currentUsername}`;
    }

    // 3. Update Markdown Codes
    const markdownStats = `![GitHub Stats](${statsUrl})`;
    const markdownLanguages = `![Lenguajes más usados](${languagesUrl})`;
    const markdownRepo = `![Repositorio Destacado](${repoUrl})`;
    const markdownRank = `![Rango de Desarrollador](${rankUrl})`;
    const markdownStreak = `![Racha de Contribuciones](${streakUrl})`;
    const markdownTrophies = `![Trofeos de GitHub](${trophiesUrl})`;
    const markdownTopRepos = `![Top Repositorios](${topReposUrl})`;
    const markdownViews = `![Visitas de Perfil](${viewsUrl})`;

    if (markdownStatsCode) markdownStatsCode.textContent = markdownStats;
    if (markdownLanguagesCode) markdownLanguagesCode.textContent = markdownLanguages;
    if (markdownRepoCode) markdownRepoCode.textContent = markdownRepo;
    if (markdownRankCode) markdownRankCode.textContent = markdownRank;
    if (markdownStreakCode) markdownStreakCode.textContent = markdownStreak;
    if (markdownTrophiesCode) markdownTrophiesCode.textContent = markdownTrophies;
    if (markdownTopReposCode) markdownTopReposCode.textContent = markdownTopRepos;
    if (markdownViewsCode) markdownViewsCode.textContent = markdownViews;

    setTimeout(() => {
      loadMetrics();
    }, 1500);
  }

  // Update only the Profile Views Card preview in real-time
  function updateViewsCard() {
    if (!currentUsername) return;

    const origin = window.location.origin;
    const labelVal = viewsLabel ? viewsLabel.value.trim() : '';
    const colorVal = viewsColor ? viewsColor.value.trim() : '';
    const styleVal = viewsStyle ? viewsStyle.value : '';

    let viewsUrl = `${origin}/api/views?username=${currentUsername}&theme=${currentTheme}`;
    if (labelVal) viewsUrl += `&label=${encodeURIComponent(labelVal)}`;
    if (colorVal) viewsUrl += `&color=${encodeURIComponent(colorVal)}`;
    if (styleVal) viewsUrl += `&style=${encodeURIComponent(styleVal)}`;

    if (viewsImg) {
      const cacheBuster = `&t=${Date.now()}`;
      viewsImg.src = viewsUrl + cacheBuster;
    }

    const markdownViews = `![Visitas de Perfil](${viewsUrl})`;
    if (markdownViewsCode) markdownViewsCode.textContent = markdownViews;

    updateSampleReadmeText();
  }

  // Manage image load cycles
  function showImageLoading(
    imgElement: HTMLImageElement | null,
    placeholderElement: HTMLElement | null
  ) {
    if (!imgElement || !placeholderElement) return;
    imgElement.classList.add('hidden');
    placeholderElement.classList.remove('hidden');

    const codeBlock = imgElement
      .closest('.card-preview-wrapper')
      ?.querySelector('.code-block-wrapper');
    if (codeBlock) {
      codeBlock.classList.add('hidden');
    }

    let svgIcon: string;
    if (placeholderElement.id === 'stats-placeholder') {
      svgIcon = `
        <svg class="placeholder-svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10" />
          <line x1="12" y1="20" x2="12" y2="4" />
          <line x1="6" y1="20" x2="6" y2="14" />
        </svg>
      `;
    } else if (placeholderElement.id === 'languages-placeholder') {
      svgIcon = `
        <svg class="placeholder-svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6" />
          <polyline points="8 6 2 12 8 18" />
        </svg>
      `;
    } else if (placeholderElement.id === 'repo-placeholder') {
      svgIcon = `
        <svg class="placeholder-svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20v3H6.5a1.5 1.5 0 0 0 0 3H20v2H6.5A2.5 2.5 0 0 1 4 22.5v-3z" />
          <path d="M6 2H20v15H6.5A2.5 2.5 0 0 0 4 19.5V3A1 1 0 0 1 5 2h1z" />
        </svg>
      `;
    } else if (placeholderElement.id === 'trophies-placeholder') {
      svgIcon = `
        <svg class="placeholder-svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
          <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
          <path d="M4 22h16" />
          <path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34" />
          <path d="M12 2a6 6 0 0 1 6 6v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8a6 6 0 0 1 6-6z" />
        </svg>
      `;
    } else {
      svgIcon = `
        <svg class="placeholder-svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      `;
    }

    const pulseIcon = placeholderElement.querySelector('.pulse-icon');
    const pText = placeholderElement.querySelector('p');
    if (pulseIcon) pulseIcon.innerHTML = svgIcon;
    if (pText) pText.textContent = 'Consultando datos en GitHub...';
  }

  // Setup Image Load Listeners Helper
  function setupImageEvents(
    imgElement: HTMLImageElement | null,
    placeholderElement: HTMLElement | null,
    errorText: string
  ) {
    if (!imgElement || !placeholderElement) return;

    imgElement.addEventListener('load', () => {
      placeholderElement.classList.add('hidden');
      imgElement.classList.remove('hidden');

      const codeBlock = imgElement
        .closest('.card-preview-wrapper')
        ?.querySelector('.code-block-wrapper');
      if (codeBlock) {
        codeBlock.classList.remove('hidden');
      }
      imageFinishedLoading();
    });

    imgElement.addEventListener('error', () => {
      const pulseIcon = placeholderElement.querySelector('.pulse-icon');
      const pText = placeholderElement.querySelector('p');

      if (pulseIcon) {
        pulseIcon.innerHTML = `
          <svg class="placeholder-svg error" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#f85149" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
        `;
      }
      if (pText) pText.textContent = errorText;

      const codeBlock = imgElement
        .closest('.card-preview-wrapper')
        ?.querySelector('.code-block-wrapper');
      if (codeBlock) {
        codeBlock.classList.add('hidden');
      }
      imageFinishedLoading();
    });
  }

  // Bind image event listeners
  setupImageEvents(statsImg, statsPlaceholder, 'Error al cargar tarjeta. Verifica el usuario.');
  setupImageEvents(languagesImg, languagesPlaceholder, 'Error al cargar lenguajes.');
  setupImageEvents(repoImg, repoPlaceholder, 'Error al cargar repositorio.');
  setupImageEvents(rankImg, rankPlaceholder, 'Error al cargar rango.');
  setupImageEvents(streakImg, streakPlaceholder, 'Error al cargar racha de contribuciones.');
  setupImageEvents(trophiesImg, trophiesPlaceholder, 'Error al cargar trofeos.');
  setupImageEvents(topReposImg, topReposPlaceholder, 'Error al cargar repositorios.');
  setupImageEvents(viewsImg, viewsPlaceholder, 'Error al cargar contador de visitas.');

  // Setup Clipboard Copy handlers
  setupCopyButton(btnCopyStats, markdownStatsCode);
  setupCopyButton(btnCopyLanguages, markdownLanguagesCode);
  setupCopyButton(btnCopyRepo, markdownRepoCode);
  setupCopyButton(btnCopyRank, markdownRankCode);
  setupCopyButton(btnCopyStreak, markdownStreakCode);
  setupCopyButton(btnCopyTrophies, markdownTrophiesCode);
  setupCopyButton(btnCopyTopRepos, markdownTopReposCode);
  setupCopyButton(btnCopyViews, markdownViewsCode);

  // Setup Sample README.md copy button
  const btnCopySampleReadme = document.getElementById('btn-copy-sample-readme');
  const sampleReadmeTextarea = document.getElementById('sample-readme-textarea') as HTMLTextAreaElement | null;

  btnCopySampleReadme?.addEventListener('click', async () => {
    if (!sampleReadmeTextarea || !sampleReadmeTextarea.value) return;
    try {
      await navigator.clipboard.writeText(sampleReadmeTextarea.value);
      showToast(t('msg_copy_readme_success', currentLocale), 'success');
    } catch (err) {
      console.error('Error copying sample README:', err);
      showToast(t('msg_copy_readme_error', currentLocale), 'error');
    }
  });

  // Setup Sample README Layout Selector Buttons
  const btnLayoutVertical = document.getElementById('btn-readme-layout-vertical');
  const btnLayoutGrid = document.getElementById('btn-readme-layout-grid');

  btnLayoutVertical?.addEventListener('click', () => {
    currentReadmeLayout = 'vertical';
    btnLayoutVertical.classList.add('active');
    btnLayoutVertical.style.background = 'rgba(56,189,248,0.15)';
    btnLayoutVertical.style.color = 'var(--text-primary)';

    btnLayoutGrid?.classList.remove('active');
    if (btnLayoutGrid) {
      btnLayoutGrid.style.background = 'transparent';
      btnLayoutGrid.style.color = 'var(--text-secondary)';
    }

    updateSampleReadmeText();
  });

  btnLayoutGrid?.addEventListener('click', () => {
    currentReadmeLayout = 'grid';
    btnLayoutGrid.classList.add('active');
    btnLayoutGrid.style.background = 'rgba(56,189,248,0.15)';
    btnLayoutGrid.style.color = 'var(--text-primary)';

    btnLayoutVertical?.classList.remove('active');
    if (btnLayoutVertical) {
      btnLayoutVertical.style.background = 'transparent';
      btnLayoutVertical.style.color = 'var(--text-secondary)';
    }

    updateSampleReadmeText();
  });

  // Setup View Mode Tabs (Code vs Live Preview)
  const tabReadmeCode = document.getElementById('tab-readme-code');
  const tabReadmePreview = document.getElementById('tab-readme-preview');
  const sampleReadmeTextareaEl = document.getElementById('sample-readme-textarea');
  const sampleReadmeRenderedEl = document.getElementById('sample-readme-rendered');

  tabReadmeCode?.addEventListener('click', () => {
    tabReadmeCode.classList.add('active');
    tabReadmeCode.style.background = 'var(--accent-color)';
    tabReadmeCode.style.color = '#000';
    tabReadmeCode.style.fontWeight = '700';

    tabReadmePreview?.classList.remove('active');
    if (tabReadmePreview) {
      tabReadmePreview.style.background = 'transparent';
      tabReadmePreview.style.color = 'var(--text-secondary)';
      tabReadmePreview.style.fontWeight = '600';
    }

    sampleReadmeTextareaEl?.classList.remove('hidden');
    sampleReadmeRenderedEl?.classList.add('hidden');
  });

  tabReadmePreview?.addEventListener('click', () => {
    tabReadmePreview.classList.add('active');
    tabReadmePreview.style.background = 'var(--accent-color)';
    tabReadmePreview.style.color = '#000';
    tabReadmePreview.style.fontWeight = '700';

    tabReadmeCode?.classList.remove('active');
    if (tabReadmeCode) {
      tabReadmeCode.style.background = 'transparent';
      tabReadmeCode.style.color = 'var(--text-secondary)';
      tabReadmeCode.style.fontWeight = '600';
    }

    sampleReadmeTextareaEl?.classList.add('hidden');
    sampleReadmeRenderedEl?.classList.remove('hidden');
  });

  // Setup views badge options change listeners (real-time updates)
  viewsStyle?.addEventListener('change', () => {
    updateViewsCard();
  });
  viewsLabel?.addEventListener('input', () => {
    updateViewsCard();
  });
  viewsColor?.addEventListener('input', () => {
    updateViewsCard();
  });

  // --- Private Token Management UI Logic ---
  const tokenUsername = document.getElementById('token-username') as HTMLInputElement | null;
  const tokenInput = document.getElementById('token-input') as HTMLInputElement | null;
  const tokenConsent = document.getElementById('token-consent') as HTMLInputElement | null;
  const btnSaveToken = document.getElementById('btn-save-token');

  const tokenUnregistered = document.getElementById('token-unregistered');
  const tokenRegistered = document.getElementById('token-registered');
  const tokenRevokeInput = document.getElementById('token-revoke-input') as HTMLInputElement | null;
  const btnRevokeToken = document.getElementById('btn-revoke-token');
  const tokenStatusMsg = document.getElementById('token-status-msg');

  // Helper to show status messages
  function showStatus(text: string, type = 'success') {
    if (!tokenStatusMsg) return;
    tokenStatusMsg.textContent = text;
    tokenStatusMsg.className = 'token-status-msg'; // reset classes
    tokenStatusMsg.classList.remove('hidden');
    if (type === 'success') {
      tokenStatusMsg.style.background = 'rgba(74, 222, 128, 0.1)';
      tokenStatusMsg.style.color = '#4ade80';
      tokenStatusMsg.style.border = '1px solid rgba(74, 222, 128, 0.2)';
      tokenStatusMsg.style.padding = '10px';
      tokenStatusMsg.style.borderRadius = '6px';
      tokenStatusMsg.style.marginTop = '10px';
    } else {
      tokenStatusMsg.style.background = 'rgba(248, 81, 73, 0.1)';
      tokenStatusMsg.style.color = '#f85149';
      tokenStatusMsg.style.border = '1px solid rgba(248, 81, 73, 0.2)';
      tokenStatusMsg.style.padding = '10px';
      tokenStatusMsg.style.borderRadius = '6px';
      tokenStatusMsg.style.marginTop = '10px';
    }
  }

  function hideStatus() {
    tokenStatusMsg?.classList.add('hidden');
  }

  // Load and show initial token state
  const storedRegUser = localStorage.getItem('registered-github-username');
  if (storedRegUser) {
    showRegisteredState();
    if (usernameInput) {
      usernameInput.value = storedRegUser;
      submitUsername();
    }
  }

  function showRegisteredState() {
    if (tokenUnregistered) tokenUnregistered.classList.add('hidden');
    if (tokenRegistered) tokenRegistered.classList.remove('hidden');
    hideStatus();
  }

  function showUnregisteredState() {
    if (tokenRegistered) tokenRegistered.classList.add('hidden');
    if (tokenUnregistered) tokenUnregistered.classList.remove('hidden');
    hideStatus();
    if (tokenInput) tokenInput.value = '';
    if (tokenRevokeInput) tokenRevokeInput.value = '';
    if (tokenConsent) tokenConsent.checked = false;
    if (tokenUsername) {
      tokenUsername.value = '';
    }
  }

  // Completely reset the entire dashboard UI and statistics
  function resetAppUI() {
    if (usernameInput) usernameInput.value = '';
    if (repoInput) repoInput.value = '';
    currentUsername = '';
    currentRepo = '';

    updateThemeSelectorsState();

    if (statsImg) statsImg.classList.add('hidden');
    if (statsPlaceholder) statsPlaceholder.classList.remove('hidden');

    if (languagesImg) languagesImg.classList.add('hidden');
    if (languagesPlaceholder) languagesPlaceholder.classList.remove('hidden');

    if (repoImg) repoImg.classList.add('hidden');
    if (repoPlaceholder) repoPlaceholder.classList.remove('hidden');

    if (rankImg) rankImg.classList.add('hidden');
    if (rankPlaceholder) rankPlaceholder.classList.remove('hidden');

    if (streakImg) streakImg.classList.add('hidden');
    if (streakPlaceholder) streakPlaceholder.classList.remove('hidden');

    if (trophiesImg) trophiesImg.classList.add('hidden');
    if (trophiesPlaceholder) trophiesPlaceholder.classList.remove('hidden');

    if (viewsImg) viewsImg.classList.add('hidden');
    if (viewsPlaceholder) viewsPlaceholder.classList.remove('hidden');

    if (viewsLabel) viewsLabel.value = 'Profile views';
    if (viewsColor) viewsColor.value = '';
    if (viewsStyle) viewsStyle.value = 'flat';

    if (codeBlockWrappers) {
      codeBlockWrappers.forEach((wrapper) => {
        wrapper.classList.add('hidden');
      });
    }

    if (sampleReadmeTextarea) {
      sampleReadmeTextarea.value = '';
    }
  }

  // Handle register
  btnSaveToken?.addEventListener('click', async () => {
    if (!tokenUsername || !tokenInput || !tokenConsent || !globalLoading) return;
    hideStatus();
    const username = tokenUsername.value.trim();
    const token = tokenInput.value.trim();
    const consentAccepted = tokenConsent.checked;

    if (!username) {
      showStatus(t('msg_enter_username', currentLocale), 'error');
      return;
    }
    if (!token) {
      showStatus(t('msg_enter_token', currentLocale), 'error');
      return;
    }
    if (!consentAccepted) {
      showStatus(t('msg_accept_consent', currentLocale), 'error');
      return;
    }

    try {
      globalLoading.classList.remove('hidden');
      const response = await fetch('/api/tokens/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, token, consentAccepted })
      });

      const data = await response.json();
      if (response.ok) {
        localStorage.setItem('registered-github-username', username);
        showRegisteredState();
        showStatus(data.message, 'success');

        if (usernameInput) {
          usernameInput.value = username;
          submitUsername();
        }
      } else {
        showStatus(data.error || t('msg_register_token_error', currentLocale), 'error');
      }
    } catch (err) {
      console.error(err);
      showStatus(t('msg_network_error', currentLocale), 'error');
    } finally {
      globalLoading.classList.add('hidden');
    }
  });

  // Handle revoke
  btnRevokeToken?.addEventListener('click', async () => {
    if (!tokenUsername || !tokenRevokeInput || !globalLoading) return;
    hideStatus();
    const username =
      localStorage.getItem('registered-github-username') || tokenUsername.value.trim();
    const token = tokenRevokeInput.value.trim();

    if (!username) {
      showStatus(t('msg_no_registered_user', currentLocale), 'error');
      return;
    }
    if (!token) {
      showStatus(t('msg_token_required_revoke', currentLocale), 'error');
      return;
    }

    try {
      globalLoading.classList.remove('hidden');
      const response = await fetch('/api/tokens/revoke', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`
        },
        body: JSON.stringify({ username })
      });

      const data = await response.json();
      if (response.ok) {
        localStorage.removeItem('registered-github-username');
        showUnregisteredState();
        showStatus(data.message, 'success');
        resetAppUI();
      } else {
        showStatus(data.error || t('msg_revoke_token_error', currentLocale), 'error');
      }
    } catch (err) {
      console.error(err);
      showStatus(t('msg_network_error', currentLocale), 'error');
    } finally {
      globalLoading.classList.add('hidden');
    }
  });

  // Handle Purge Data
  const btnOpenPurgeModal = document.getElementById('btn-open-purge-modal');
  const purgeModal = document.getElementById('purge-modal');
  const purgeUsername = document.getElementById('purge-username') as HTMLInputElement | null;
  const purgeToken = document.getElementById('purge-token') as HTMLInputElement | null;
  const btnClosePurge = document.getElementById('btn-close-purge');
  const btnConfirmPurge = document.getElementById('btn-confirm-purge') as HTMLButtonElement | null;

  btnOpenPurgeModal?.addEventListener('click', () => {
    if (purgeModal) {
      purgeModal.classList.remove('hidden');
    }
    if (purgeUsername) purgeUsername.value = '';
    if (purgeToken) purgeToken.value = '';
    updatePurgeConfirmButtonState();
  });

  btnClosePurge?.addEventListener('click', () => {
    if (purgeModal) {
      purgeModal.classList.add('hidden');
    }
  });

  function updatePurgeConfirmButtonState() {
    if (!btnConfirmPurge) return;
    const hasUsername = purgeUsername && purgeUsername.value.trim() !== '';
    const hasToken = purgeToken && purgeToken.value.trim() !== '';
    if (hasUsername && hasToken) {
      btnConfirmPurge.style.opacity = '1';
      btnConfirmPurge.style.pointerEvents = 'auto';
    } else {
      btnConfirmPurge.style.opacity = '0.5';
      btnConfirmPurge.style.pointerEvents = 'none';
    }
  }

  purgeUsername?.addEventListener('input', updatePurgeConfirmButtonState);
  purgeToken?.addEventListener('input', updatePurgeConfirmButtonState);

  btnConfirmPurge?.addEventListener('click', async () => {
    if (!purgeUsername || !purgeToken || !globalLoading) return;
    const username = purgeUsername.value.trim();
    const token = purgeToken.value.trim();

    if (!username || !token) return;

    try {
      globalLoading.classList.remove('hidden');
      const response = await fetch('/api/users/purge', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`
        },
        body: JSON.stringify({ username })
      });

      const data = await response.json();
      if (response.ok) {
        if (purgeModal) {
          purgeModal.classList.add('hidden');
        }
        localStorage.removeItem('registered-github-username');
        showUnregisteredState();
        showStatus(data.message, 'success');
        resetAppUI();
      } else {
        alert(data.error || 'Error al intentar purgar los datos.');
      }
    } catch (err) {
      console.error(err);
      alert('Error de red al intentar purgar los datos.');
    } finally {
      globalLoading.classList.add('hidden');
    }
  });

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast ${type}`;

    const iconSvg =
      type === 'success'
        ? `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
         </svg>`
        : `<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
         </svg>`;

    toast.innerHTML = `
      <span class="toast-icon">${iconSvg}</span>
      <span>${message}</span>
      <div class="toast-progress"></div>
    `;

    container.appendChild(toast);

    setTimeout(() => {
      toast.classList.add('removing');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 2700);
  }

  function setupCopyButton(button: HTMLElement | null, codeElement: HTMLElement | null) {
    if (!button || !codeElement) return;
    button.addEventListener('click', async () => {
      const codeText = codeElement.textContent;
      if (!codeText) return;
      try {
        await navigator.clipboard.writeText(codeText);
        showToast(t('msg_copy_code_success', currentLocale), 'success');
      } catch (err) {
        console.error('Error al copiar al portapapeles:', err);
        showToast(t('msg_copy_code_error', currentLocale), 'error');
      }
    });
  }
  // --- Config Load Logic ---
  async function loadConfig() {
    try {
      const response = await fetch('/api/config');
      if (response.ok) {
        const config = await response.json();
        if (config.privateStatsComingSoon === false) {
          if (privateStatsBadge) {
            privateStatsBadge.classList.add('hidden');
          }
          if (tokenFormContainer) {
            tokenFormContainer.style.opacity = '1';
            tokenFormContainer.style.pointerEvents = 'auto';
            tokenFormContainer.removeAttribute('title');
          }
          if (tokenUsername) tokenUsername.removeAttribute('disabled');
          if (tokenInput) tokenInput.removeAttribute('disabled');
          if (tokenConsent) tokenConsent.removeAttribute('disabled');
          if (btnSaveToken) btnSaveToken.removeAttribute('disabled');
        } else {
          if (privateStatsBadge) {
            privateStatsBadge.classList.remove('hidden');
          }
          if (tokenFormContainer) {
            tokenFormContainer.style.opacity = '0.55';
            tokenFormContainer.style.pointerEvents = 'none';
            tokenFormContainer.setAttribute(
              'title',
              'Esta característica estará disponible próximamente'
            );
          }
          if (tokenUsername) tokenUsername.setAttribute('disabled', '');
          if (tokenInput) tokenInput.setAttribute('disabled', '');
          if (tokenConsent) tokenConsent.setAttribute('disabled', '');
          if (btnSaveToken) btnSaveToken.setAttribute('disabled', '');
        }
      }
    } catch (error) {
      console.error('Error loading config:', error);
    }
  }
  // --- URL Parameters Initialization on Load ---
  function initParamsFromUrl() {
    const urlParams = new URLSearchParams(window.location.search);
    const userParam = urlParams.get('user') || urlParams.get('username');
    const themeParam = urlParams.get('theme');
    const localeParam = urlParams.get('locale');

    if (themeParam) {
      currentTheme = themeParam;
      const option = document.querySelector(`.theme-option[data-theme="${themeParam}"]`);
      if (option) {
        themeOptions.forEach((opt) => opt.classList.remove('active'));
        option.classList.add('active');
      }
    }

    if (localeParam === 'en' || localeParam === 'es') {
      currentLocale = localeParam;
      if (localeSelect) {
        localeSelect.value = localeParam;
      }
    }

    updateDomTranslations(currentLocale);

    if (userParam && usernameInput) {
      usernameInput.value = userParam;
      currentUsername = userParam;
      updateThemeSelectorsState();
      updateCards();
    }
  }
  loadConfig().then(() => {
    initParamsFromUrl();
  });
</script>
