---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Centro de Ayuda y Documentación | GitHub Helpers"
  description="Guías oficiales, tutoriales y documentación sobre cómo crear tu perfil en GitHub, gestionar tokens de acceso seguro y proteger tus datos."
>
  <header class="app-header">
    <div class="header-top-row">
      <a href="/" class="logo" style="text-decoration: none">
        <svg
          class="logo-icon"
          viewBox="0 0 24 24"
          width="36"
          height="36"
          fill="none"
          stroke="url(#logo-grad)"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#38bdf8"></stop>
              <stop offset="100%" stop-color="#a855f7"></stop>
            </linearGradient>
          </defs>
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
        <h1 style="margin: 0">GitHub <span class="accent-text">Helpers</span></h1>
      </a>
    </div>
  </header>

  <main class="help-hub-container">
    <div class="help-hub-header">
      <span class="hub-badge">Centro de Ayuda</span>
      <h2>¿En qué te podemos ayudar hoy?</h2>
      <p style="color: var(--text-secondary); margin-top: 10px; font-size: 1.05rem;">
        Explora nuestras guías paso a paso para configurar tu perfil en GitHub y gestionar la seguridad de tus métricas.
      </p>
    </div>

    <!-- Categories Grid -->
    <div class="help-categories-grid">
      <!-- Category 1: GitHub Profile -->
      <a href="/help/github-profile" class="category-card glass-card">
        <div class="card-icon-wrapper" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8;">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        </div>
        <div class="card-content">
          <h3>Crear Perfil en GitHub (README.md)</h3>
          <p>
            Aprende a habilitar el repositorio especial <code>username/username</code> y pegar tus tarjetas estéticas en tu perfil.
          </p>
          <span class="read-guide-link">Ver Guía Completa →</span>
        </div>
      </a>

      <!-- Category 2: Create Tokens (PAT) -->
      <a href="/help/tokens" class="category-card glass-card">
        <div class="card-icon-wrapper" style="background: rgba(168, 85, 247, 0.1); color: #a855f7;">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="8.5" cy="7" r="4"></circle>
            <line x1="20" y1="8" x2="20" y2="14"></line>
            <line x1="23" y1="11" x2="17" y2="11"></line>
          </svg>
        </div>
        <div class="card-content">
          <h3>Personal Access Tokens (PAT)</h3>
          <p>
            Paso a paso para generar un token Fine-grained de solo lectura para sumar estadísticas de repositorios privados.
          </p>
          <span class="read-guide-link">Ver Guía Completa →</span>
        </div>
      </a>

      <!-- Category 3: Security & Encryption -->
      <a href="/help/security" class="category-card glass-card">
        <div class="card-icon-wrapper" style="background: rgba(74, 222, 128, 0.1); color: #4ade80;">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div class="card-content">
          <h3>Seguridad y Cifrado de Datos</h3>
          <p>
            Conoce cómo protegemos tus datos con cifrado simétrico AES-256-GCM y aislamiento de claves en servidor.
          </p>
          <span class="read-guide-link">Ver Guía Completa →</span>
        </div>
      </a>

      <!-- Category 4: Token Revocation & Purge -->
      <a href="/help/revocation" class="category-card glass-card">
        <div class="card-icon-wrapper" style="background: rgba(248, 81, 73, 0.1); color: #f85149;">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
        </div>
        <div class="card-content">
          <h3>Revocación y Purgado de Datos</h3>
          <p>
            Métodos para eliminar tu token almacenado, purgar tu historial de métricas o revocar accesos en cualquier momento.
          </p>
          <span class="read-guide-link">Ver Guía Completa →</span>
        </div>
      </a>
    </div>

    <!-- Back to Generator Button -->
    <a href="/" class="btn-back" style="margin-top: 20px;">
      <svg
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Volver al Generador de Tarjetas
    </a>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Backward compatibility: redirect hash navigation to subpages
  const hash = window.location.hash.toLowerCase();
  if (hash === '#github-profile') {
    window.location.replace('/help/github-profile');
  } else if (hash === '#tokens' || hash === '#pat') {
    window.location.replace('/help/tokens');
  } else if (hash === '#security') {
    window.location.replace('/help/security');
  } else if (hash === '#revocation' || hash === '#purge') {
    window.location.replace('/help/revocation');
  }
</script>

<style>
  .help-hub-container {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 16px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .help-hub-header {
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 24px;
  }
  .hub-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    background: rgba(56, 189, 248, 0.12);
    color: var(--accent-color);
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 12px;
    border: 1px solid rgba(56, 189, 248, 0.2);
  }
  .help-hub-header h2 {
    font-size: 2.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #fff 0%, var(--text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
  }
  .help-categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .category-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.25s ease;
    border: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.02);
  }
  .category-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-color);
    box-shadow: 0 8px 24px var(--accent-glow);
    background: rgba(255, 255, 255, 0.04);
  }
  .card-icon-wrapper {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .card-content p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 16px;
  }
  .read-guide-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent-color);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .btn-back {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    font-weight: 500;
    transition: var(--transition-smooth);
  }
  .btn-back:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--accent-color);
    box-shadow: 0 0 15px var(--accent-glow);
  }
</style>
